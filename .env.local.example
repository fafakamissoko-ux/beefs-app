# ====================================
# BEEFS - ENVIRONMENT VARIABLES
# ====================================

# URL canonique du site en prod : OAuth Google (redirectTo), e-mail auth, Stripe, et redirection www↔apex.
# Ex. https://beefs.live — la même URL doit être dans Supabase → Auth → URL (Site URL + Redirect URLs).
NEXT_PUBLIC_APP_URL=

# Optionnel : désactiver le mur bêta (ex. variable Preview uniquement sur Vercel)
# NEXT_PUBLIC_DISABLE_BETA_GATE=true

# ====================================
# SUPABASE
# ====================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ====================================
# STRIPE
# ====================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (from Stripe Dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_POPULAR=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_VIP=price_...

# ====================================
# DAILY.CO (VIDEO/AUDIO)
# ====================================
# Ton domaine Daily.co (ex: your-account.daily.co)
NEXT_PUBLIC_DAILY_DOMAIN=your-account.daily.co

# API Key (obtenue depuis Dashboard → Developers → API Keys)
DAILY_API_KEY=abc123def456ghi789jkl012mno345pqr678stu901

# Visio : les salles beef sont créées en « private » ; le join utilise un meeting token
# émis par /api/daily/meeting-token (user_id = UUID Supabase). SUPABASE_SERVICE_ROLE_KEY requis côté API.
#
# Anciennes rooms encore « public » : admin dashboard → « Daily — salles beef en private »
# ou GET/POST /api/admin/daily/rooms-migrate-private (admin JWT ou x-admin-secret si ADMIN_SECRET défini).

# ====================================
# APP CONFIG
# ====================================
NEXT_PUBLIC_URL=http://localhost:3003

# ====================================
# MONITORING (optionnel)
# ====================================
# Erreurs navigateur → https://sentry.io (créer un projet JS / Next)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ====================================
# OPTIONAL (PHASE 2)
# ====================================
# VAPID Keys for Push Notifications
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Twilio (for Phone Auth)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Flutterwave (for Mobile Money Africa)
# FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=

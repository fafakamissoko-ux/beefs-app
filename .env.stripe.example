// Stripe Configuration
// Copy this file to .env.local and fill in your Stripe keys

// Get your keys from: https://dashboard.stripe.com/apikeys

// PUBLIC KEY (Safe for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

// SECRET KEY (Backend only - NEVER expose to frontend!)
STRIPE_SECRET_KEY=sk_test_your_key_here

// WEBHOOK SECRET (Get from: https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

// POINT PACK PRICE IDS (Create these in Stripe Dashboard → Products)
// These are Price IDs, not Product IDs!
STRIPE_PRICE_STARTER=price_starter_pack_id
STRIPE_PRICE_POPULAR=price_popular_pack_id
STRIPE_PRICE_PREMIUM=price_premium_pack_id
STRIPE_PRICE_VIP=price_vip_pack_id

// SUBSCRIPTION PRICE ID (For Premium Pass)
STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly_id
